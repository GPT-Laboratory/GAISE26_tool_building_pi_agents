JOIN_CODE=workshop2026
ADMIN_TOKEN=change-me-before-session
POOL_SIZE=40
PORT=3000

# Model: any model ID accepted by your provider
# OpenRouter examples: moonshotai/kimi-k2, google/gemini-2.5-pro
# OpenAI examples:     gpt-4o, gpt-4o-mini
# Ollama example:      llama3.2 (with OPENAI_BASE_URL=http://localhost:11434/v1)
PI_MODEL=gpt-4o-mini

# API base URL — any OpenAI-compatible endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama

# API key — choose one:
# Option A: single key (simplest)
OPENAI_API_KEY=sk-...
# Option B: file with one key per line (round-robins across containers)
# OPENAI_KEY_FILE=./keys.txt
