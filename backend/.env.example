JOIN_CODE=workshop2026
ADMIN_TOKEN=change-me-before-session
POOL_SIZE=40
PORT=3000
# RATE_LIMIT_MAX=0   # uncomment to disable rate limiting during load tests (default: 30/min)

# Model passed to pi as: pi --model $PI_MODEL --api-key $OPENAI_API_KEY
# pi routes by provider prefix — include it explicitly to avoid ambiguity:
#   OpenRouter: openrouter/moonshotai/kimi-k2.5  or  openrouter/google/gemini-2.5-pro
#   OpenAI:     openai/gpt-4o-mini
#   Bare id:    pi will auto-route (e.g. moonshotai/kimi-k2.5 → openrouter)
PI_MODEL=openrouter/moonshotai/kimi-k2.5

# API key for the provider above (passed as --api-key to pi)
OPENAI_API_KEY=sk-or-v1-...
# Option B: file with one key per line (round-robins across containers)
# OPENAI_KEY_FILE=./keys.txt
